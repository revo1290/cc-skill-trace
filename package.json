{
  "name": "cc-skill-trace",
  "version": "0.11.0",
  "description": "Skill invocation debugger and visualizer for Claude Code — see which skills fired, when, and why",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "skills",
    "debugger",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "author": "revo1290 (https://github.com/revo1290)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revo1290/cc-skill-trace.git"
  },
  "homepage": "https://github.com/revo1290/cc-skill-trace#readme",
  "bugs": {
    "url": "https://github.com/revo1290/cc-skill-trace/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "cc-skill-trace": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "src/skill/SKILL.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test src/core/store.test.ts src/core/parser.test.ts src/cli/format.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
